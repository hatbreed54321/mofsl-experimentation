# ============================================================
# MOFSL Experimentation Platform — Backend Environment Config
# Copy to .env and fill in values for local development.
# NEVER commit .env to version control.
# ============================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# PostgreSQL (AWS RDS in production; docker-compose locally)
DATABASE_URL=postgresql://experimentation:secret@localhost:5432/experimentation
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Redis (AWS ElastiCache in production; docker-compose locally)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka (AWS MSK in production; docker-compose locally — leave empty to disable in dev)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=experimentation-backend

# ClickHouse (analytics — not needed for Phase 6)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=experimentation
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# S3 (LocalStack in dev; real S3 in production)
S3_BUCKET=mofsl-experimentation-uploads
S3_REGION=ap-south-1
# Set this for LocalStack in local dev:
S3_ENDPOINT=http://localhost:4566
# Leave empty for real AWS (uses IAM role in ECS):
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Auth — JWT secret for dashboard routes
# In production this comes from MOFSL SSO (SAML/OIDC); here it's used to validate signed JWTs
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY=8h

# SSO (Phase 8 — leave empty in Phase 6)
SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
